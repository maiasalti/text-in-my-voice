# Copy this to .env and put your real key in it:
#     cp .env.example .env
# .env is gitignored — your key stays local and is never committed.

ANTHROPIC_API_KEY=sk-ant-your-real-key-here

# Optional toggles (handy for background / LaunchAgent use):
# DRAFTER_NOTIFY=1     # post a macOS notification for each draft
# DRAFTER_CLIPBOARD=1  # copy the top suggestion to the clipboard
